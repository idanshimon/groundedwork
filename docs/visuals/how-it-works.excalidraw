    { "type": "text", "id": "t_hybrid", "x": 70, "y": 478, "width": 180, "height": 64, "text": "OPT-IN: hybrid\nadd an embedder ->\nfuse BM25 + dense (RRF)\ncloses paraphrase gap", "fontSize": 14, "fontFamily": 1, "strokeColor": "#1e1e1e", "textAlign": "center", "verticalAlign": "middle", "containerId": "hybrid", "originalText": "OPT-IN: hybrid\nadd an embedder ->\nfuse BM25 + dense (RRF)\ncloses paraphrase gap", "autoResize": true },

