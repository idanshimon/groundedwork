    { "type": "text", "id": "note", "x": 60, "y": 610, "text": "Default = pure BM25, zero deps.\nHybrid is optional and never\ncalls a generation model (BYOM).", "fontSize": 14, "fontFamily": 1, "strokeColor": "#757575", "originalText": "Default = pure BM25, zero deps.\nHybrid is optional and never\ncalls a generation model (BYOM).", "autoResize": true }
