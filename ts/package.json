{
  "name": "groundedwork",
  "version": "0.1.0",
  "description": "Retrieval that knows when it doesn't know. A tiny, dependency-free BM25 working-set layer for giving an LLM a knowledge base bigger than its context window — grounded and abstaining by default.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "node --test --experimental-strip-types 'test/*.test.ts'",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["rag", "retrieval", "bm25", "llm", "context", "grounding", "abstention", "working-set"],
  "author": "Idan Shimon",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
